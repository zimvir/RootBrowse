{
  "Browse": {
    "attribute": {
      "_page": {
        "type": "ChromiumPage",
        "description": "DrissionPage 底层实例"
      },
      "TabManager": {
        "type": "class",
        "description": "标签页管理器",
        "attribute": {
          "_page": {
            "type": "ChromiumPage"
          },
          "_tabs": {
            "type": "list[dict]",
            "description": "所有标签页信息 [{url, title}, ...]"
          },
          "_current_index": {
            "type": "int"
          }
        },
        "method": {
          "new_tab": {
            "args": ["url: str"],
            "returns": "int"
          },
          "close_tab": {
            "args": [],
            "returns": "None"
          },
          "switch_to_tab": {
            "args": ["index: int"],
            "returns": "None"
          },
          "tabs_count": {
            "args": [],
            "returns": "int"
          },
          "current_index": {
            "args": [],
            "returns": "int"
          }
        }
      },
      "ElementOperator": {
        "type": "class",
        "description": "元素操作器",
        "attribute": {
          "_element_map": {
            "type": "dict[str, Element]"
          }
        },
        "method": {
          "click": {
            "args": ["ref: str"],
            "returns": "dict"
          },
          "input_by_ref": {
            "args": ["ref: str", "text: str", "clear: bool = False"],
            "returns": "dict"
          },
          "hover": {
            "args": ["ref: str"],
            "returns": "dict"
          },
          "double_click": {
            "args": ["ref: str"],
            "returns": "dict"
          },
          "right_click": {
            "args": ["ref: str"],
            "returns": "dict"
          },
          "submit": {
            "args": ["ref: str"],
            "returns": "dict"
          },
          "clear": {
            "args": ["ref: str"],
            "returns": "dict"
          },
          "send_enter": {
            "args": [],
            "returns": "None"
          }
        }
      },
      "PageScanner": {
        "type": "class",
        "description": "页面扫描器",
        "attribute": {
          "_page": {
            "type": "ChromiumPage"
          },
          "_element_map": {
            "type": "dict[str, Element]"
          }
        },
        "method": {
          "get_regions": {
            "args": [],
            "returns": "list[Region]",
            "description": "返回页面语义区块列表 [{id, label, node_count}, ...]"
          },
          "get_region_summary": {
            "args": ["region_id: str"],
            "returns": "dict",
            "description": "返回区域摘要 {count, tag_counts, role_counts, text_preview}"
          },
          "match_element": {
            "args": [
              "region_id: str | list[str] | None = None",
              "query: str | None = None",
              "tag: str | None = None",
              "role: str | None = None",
              "text_contains: str | None = None",
              "limit: int = 20",
              "offset: int = 0"
            ],
            "returns": "list[dict]",
            "description": "按 region/keyword/tag/role/text 筛选元素，返回摘要列表 [{ref, text, attrs_preview}, ...]"
          },
          "get_element": {
            "args": ["ref: str"],
            "returns": "Element",
            "description": "通过 ref 获取完整元素信息"
          },
          "find_element": {
            "args": ["by: str", "value: str", "filter: dict | None = None"],
            "returns": "Element | None",
            "description": "多维度定位元素（by: xpath | role | aria_label | text）"
          }
        }
      }
    },
    "method": {
      "get": {
        "args": ["url: str"],
        "returns": "dict",
        "description": "打开 URL，返回 {url, title}"
      },
      "screenshot": {
        "args": ["path: str | None = None", "annotate: list[list[int]] | None = None"],
        "returns": "str",
        "description": "截图，annotate=[[x1,y1,x2,y2], ...] 高亮区域，返回路径或 base64"
      },
      "save_state": {
        "args": ["path: str"],
        "returns": "None",
        "description": "保存 cookies + localStorage 到文件"
      },
      "load_state": {
        "args": ["path: str"],
        "returns": "None",
        "description": "从文件恢复会话状态"
      }
    }
  }
}